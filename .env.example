# Copy to `.env` and fill in. `.env` is gitignored. Loaded by src/nexus_refactor/config.py.

# --- LLM providers (both wired; router picks per-task) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Default provider for the refactor/parse nodes.
# One of: anthropic | openai | deepseek | ollama
LLM_PROVIDER=ollama
# Model ids (override as you like)
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-v4-flash
OLLAMA_MODEL=qwen3-coder:30b

# --- Observability (LangSmith) ---
# Set TRACING=true and provide a key to see every node/LLM call/tool exec traced.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=nexus-refactor

# --- Retrieval (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# fastembed model ids (local, no API cost). bge-small is a fine default; swap to a
# code-specialized model (e.g. jinaai/jina-embeddings-v2-base-code) once you measure recall.
DENSE_EMBED_MODEL=BAAI/bge-small-en-v1.5
SPARSE_EMBED_MODEL=Qdrant/bm25

# --- Agent termination gate (Phase 1a) ---
# The self-heal loop is hard-bounded by these. It cannot spin forever.
MAX_ITERATIONS=4
# Soft token budget per run (the router/loop should respect it).
TOKEN_BUDGET=200000
